{
  "name": "saas_app",
  "private": true,
  "version": "1.0.0",
  "description": "TEM AI Studio for Crystallographic Analysis",
  "author": "Parardha Dhar",
  "type": "module",
  "homepage": ".",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.antigravity.temstudio",
    "productName": "TEM AI Studio",
    "compression": "store",
    "directories": {
      "output": "dist_electron"
    },
    "asar": true,
    "win": {
      "target": "dir"
    },
    "extraResources": [
      {
        "from": "../src",
        "to": "src",
        "filter": [
          "**/*",
          "!human_feedback",
          "!__pycache__"
        ]
      },
      {
        "from": "../weights",
        "to": "weights",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../",
        "to": ".",
        "filter": [
          "Complete_TEM_Morphology_Map.csv",
          "Complete_BCC_TEM_Morphology_Map.csv"
        ]
      }
    ]
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "chart.js": "^4.5.1",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-is": "^19.2.7",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0",
    "utif": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
